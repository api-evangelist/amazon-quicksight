    },
    "Name": {
      "@id": "aws:Name",
      "@type": "xsd:string"
    },
    "Version": {
      "@id": "aws:Version",
      "@type": "xsd:string"
    },
    "CreatedTime": {
      "@id": "aws:CreatedTime",
      "@type": "xsd:dateTime"
    },
    "LastPublishedTime": {
      "@id": "aws:LastPublishedTime",
      "@type": "xsd:dateTime"
    },
    "LastUpdatedTime": {
      "@id": "aws:LastUpdatedTime",
